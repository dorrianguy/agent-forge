# ===========================================
# Agent Forge - Environment Variables Template
# ===========================================
# INSTRUCTIONS:
# 1. Copy this file to .env.local (for Next.js) or .env (for other frameworks)
# 2. Fill in all REQUIRED variables
# 3. Configure OPTIONAL variables as needed
# 4. Never commit .env.local or .env to version control
# ===========================================

# ===========================================
# NEXT.JS PUBLIC VARIABLES (REQUIRED)
# ===========================================
# App URL - Used for redirects, webhooks, and absolute URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
# For production: NEXT_PUBLIC_APP_URL=https://agent-forge.vercel.app

# ===========================================
# ANTHROPIC API (REQUIRED)
# ===========================================
# Get your API key from: https://console.anthropic.com/
# Used for Claude AI agent interactions
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# SUPABASE (REQUIRED)
# ===========================================
# Get credentials from: https://app.supabase.com/project/_/settings/api
# Project URL format: https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxx

# Service role key (secret - never expose to client)
# Used for server-side admin operations, bypassing RLS
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxx

# Database direct connection (optional - for migrations/backups)
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-us-west-1.pooler.supabase.com:6543/postgres

# ===========================================
# STRIPE (REQUIRED FOR BILLING)
# ===========================================
# Get API keys from: https://dashboard.stripe.com/apikeys
# Start with test keys (sk_test_), then switch to live (sk_live_) for production

# Secret key - Use on server-side only
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# For production: STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Publishable key - Safe to expose on client-side
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# For production: NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook signing secret - Get from: https://dashboard.stripe.com/webhooks
# Used to verify webhook authenticity
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Price IDs - Create products at: https://dashboard.stripe.com/products
# Updated pricing: $79/month, $249/month, $799/month

# Starter Plan - $79/month recurring
# Features: 10 agents, 1,000 requests/month, email support
STRIPE_PRICE_STARTER=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Professional Plan - $249/month recurring
# Features: 50 agents, 10,000 requests/month, priority support, custom integrations
STRIPE_PRICE_PROFESSIONAL=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Enterprise Plan - $799/month recurring
# Features: Unlimited agents, unlimited requests, dedicated support, SLA, custom deployment
STRIPE_PRICE_ENTERPRISE=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# RESEND (REQUIRED FOR EMAIL)
# ===========================================
# Get API key from: https://resend.com/api-keys
# Used for transactional emails (welcome, password reset, billing notifications)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email from address - Must be verified domain in Resend
# For development: Use resend.dev domain
# For production: Use your custom domain
EMAIL_FROM=Agent Forge <noreply@agent-forge.app>

# ===========================================
# CRON JOBS & SCHEDULED TASKS (REQUIRED)
# ===========================================
# Secret token to authenticate cron job requests
# Generate a secure random string: openssl rand -base64 32
# Used in Authorization header: Bearer [CRON_SECRET]
CRON_SECRET=your-secure-random-cron-secret-here

# ===========================================
# CONTROL HUB (OPTIONAL)
# ===========================================
# Centralized management dashboard for multi-agent systems
CONTROL_HUB_URL=https://your-control-hub.vercel.app
CONTROL_HUB_APP_ID=agent-forge
CONTROL_HUB_TOKEN=your_token_from_registration

# ===========================================
# APPLICATION SETTINGS (OPTIONAL)
# ===========================================
# Environment mode
ENVIRONMENT=development
# For production: ENVIRONMENT=production

# Session secret - Generate a secure random string
# Used for encrypting session cookies
SECRET_KEY=generate-a-secure-random-string-here

# Server port (only relevant for custom Node.js servers)
PORT=8000

# ===========================================
# REDIS (OPTIONAL - FOR CACHING)
# ===========================================
# Redis connection URL for caching agent responses
# Local: redis://localhost:6379
# Upstash: redis://default:[PASSWORD]@[ENDPOINT]:6379
REDIS_URL=redis://localhost:6379

# ===========================================
# DEPLOYMENT CREDENTIALS (OPTIONAL)
# ===========================================

# Vercel - Recommended for Next.js deployments
# Get token from: https://vercel.com/account/tokens
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# Cloudflare Workers
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Railway
RAILWAY_TOKEN=

# ===========================================
# EMAIL ALTERNATIVES (OPTIONAL)
# ===========================================

# SendGrid (alternative to Resend)
SENDGRID_API_KEY=

# ===========================================
# MESSAGING INTEGRATIONS (OPTIONAL)
# ===========================================

# Slack - For agent notifications and commands
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Discord - For agent notifications and commands
DISCORD_BOT_TOKEN=

# ===========================================
# VOICE AGENT (OPTIONAL)
# ===========================================

# ElevenLabs - Text-to-Speech
# Get API key from: https://elevenlabs.io/
ELEVENLABS_API_KEY=

# Deepgram - Speech-to-Text
# Get API key from: https://console.deepgram.com/
DEEPGRAM_API_KEY=

# Twilio - Phone Number Provisioning & Calls
# Get credentials from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Telnyx (alternative to Twilio)
# Get API key from: https://portal.telnyx.com/
TELNYX_API_KEY=

# ===========================================
# ANALYTICS & MONITORING (OPTIONAL)
# ===========================================

# PostHog - Product analytics
POSTHOG_API_KEY=

# Sentry - Error tracking
SENTRY_DSN=

# ===========================================
# DEVELOPMENT HELPERS (OPTIONAL)
# ===========================================

# Enable verbose logging
DEBUG=false

# Disable SSL verification (local development only)
NODE_TLS_REJECT_UNAUTHORIZED=0
