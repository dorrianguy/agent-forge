          "Email support",
          "Website widget",
          "Voice widget"
        ]
      },
      "professional": {
        "name": "Professional",
        "price": 249,
        "interval": "month",
        "agents": 5,
        "voice_agents": 3,
        "voice_minutes": 500,
        "phone_numbers": 5,
        "concurrent_calls": 5,
        "features": [
          "5 AI Agents (text or voice)",
          "10,000 conversations/month",
          "500 voice minutes/month",
          "5 phone numbers included",
          "Advanced analytics",
          "Priority support",
          "All integrations",
          "Custom branding",
          "API access",
          "Batch calling campaigns",
          "Post-call analysis"
        ]
      },
      "enterprise": {
        "name": "Enterprise",
        "price": 799,
        "interval": "month",
        "agents": -1,
        "voice_agents": -1,
        "voice_minutes": 2000,
        "phone_numbers": -1,
        "concurrent_calls": 20,
        "features": [
          "Unlimited AI Agents",
          "Unlimited conversations",
          "2,000 voice minutes/month",
          "Unlimited phone numbers",
          "20 concurrent calls",
          "Enterprise analytics",
          "Dedicated support",
          "Custom integrations",
          "White-label option",
          "SLA guarantee",
          "On-premise option",
          "Custom TTS voice cloning"
        ]
      }
    },
    "voice_overage": {
      "per_minute_inbound": 0.05,
      "per_minute_outbound": 0.08,
      "sms_per_message": 0.01,
      "additional_number_local": 2.00,
      "additional_number_toll_free": 5.00
    }
  },
  "marketing": {
    "enabled": true,
    "post_frequency": "daily",
    "channels": ["blog", "twitter", "linkedin", "email"],
    "topics": [
      "AI agents for business",
      "Customer support automation",
      "Sales chatbots",
      "No-code AI tools",
      "Conversational AI"
    ]
  },
  "sales": {
    "enabled": true,
    "auto_qualify": true,
    "qualification_criteria": {
      "budget_min": 49,
      "use_cases": ["support", "sales", "lead_gen", "booking", "faq"],
      "company_sizes": ["startup", "smb", "enterprise"]
    }
  },
  "support": {
    "enabled": true,
    "auto_resolve": true,
    "escalation_threshold": 3,
    "business_hours": {
      "timezone": "America/Chicago",
      "start": "09:00",
      "end": "17:00"
    }
  },
  "deployment": {
    "default_target": "cloudflare",
    "supported_targets": ["cloudflare", "vercel", "aws_lambda", "docker", "railway"],
    "auto_deploy": true
  },
  "ai": {
    "provider": "anthropic",
    "model": "claude-sonnet-4-20250514",
    "max_tokens": 1000,
    "temperature": 0.7
  },
  "integrations": {
    "supported": [
      "slack",
      "discord",
      "whatsapp",
      "zapier",
      "hubspot",
      "salesforce",
      "intercom",
      "zendesk",
      "calcom",
      "twilio",
      "telnyx"
    ]
  },
  "voice": {
    "enabled": true,
    "providers": {
      "telephony": "twilio",
      "asr": "deepgram",
      "tts": "elevenlabs"
    },
    "telephony": {
      "provider": "twilio",
      "webhook_base_url": "",
      "pricing": {
        "inbound_per_minute_cents": 5,
        "outbound_per_minute_cents": 8,
        "local_number_monthly_cents": 200,
        "toll_free_monthly_cents": 500
      }
    },
    "asr": {
      "provider": "deepgram",
      "model": "nova-2",
      "default_language": "en",
      "supported_languages": ["en", "es", "fr", "de", "it", "pt", "nl", "ja", "ko", "zh"],
      "endpointing_ms": 300,
      "utterance_end_ms": 1000,
      "interim_results": true,
      "punctuate": true,
      "smart_format": true
    },
    "tts": {
      "provider": "elevenlabs",
      "default_voice": "EXAVITQu4vr4xnSDxMaL",
      "default_model": "eleven_turbo_v2",
      "output_format": "pcm_24000",
      "default_speed": 1.0,
      "default_stability": 0.5,
      "default_similarity_boost": 0.75
    },
    "pipeline": {
      "latency_target_ms": 600,
      "max_call_duration_seconds": 3600,
      "silence_timeout_seconds": 10,
      "backchannel": {
        "enabled": true,
        "phrases": ["uh-huh", "I see", "got it", "okay", "right"],
        "frequency": 0.3
      },
      "interruption": {
        "enabled": true,
        "sensitivity": 0.5
      }
    },
    "campaigns": {
      "max_concurrent_calls_per_campaign": 50,
      "default_retry_delay_minutes": 60,
      "max_retry_attempts": 3,
      "calls_per_minute_limit": 60
    },
    "analytics": {
      "post_call_analysis": true,
      "sentiment_analysis": true,
      "transcript_storage_days": 90,
      "recording_storage_days": 30
    },
    "limits": {
      "max_concurrent_calls_starter": 1,
      "max_concurrent_calls_professional": 5,
      "max_concurrent_calls_enterprise": 20
    }
  },
  "control_hub": {
    "enabled": true,
    "heartbeat_interval": 30,
    "log_levels": ["error", "warn", "info"]
  },
  "collaboration": {
    "enabled": true,
    "message_timeout": 30,
    "max_queue_size": 1000,
    "handoff_timeout": 60,
    "auto_escalate": true,
    "broadcast_insights": true
  },
  "learning": {
    "enabled": true,
    "evolution_interval_hours": 1,
    "min_samples_for_evolution": 10,
    "exploration_rate": 0.2,
    "outcome_retention_days": 90,
    "ab_testing": {
      "enabled": true,
      "min_samples_per_variant": 20,
      "significance_threshold": 0.95
    },
    "strategies": {
      "auto_evolve": true,
      "max_active_per_type": 5,
      "retirement_threshold": 0.3
    }
  },
  "workforce": {
    "enabled": true,
    "scaling_interval": 30,
    "thresholds": {
      "support_queue_threshold": 20,
      "sales_queue_threshold": 15,
      "marketing_queue_threshold": 10,
      "build_queue_threshold": 5
    },
    "performance": {
      "max_response_time_ms": 5000,
      "max_error_rate": 0.05
    },
    "limits": {
      "max_workers_per_type": 10,
      "max_total_workers": 50,
      "min_workers_per_type": 0
    },
    "timing": {
      "scale_up_cooldown_seconds": 60,
      "scale_down_cooldown_seconds": 300,
      "idle_threshold_seconds": 300
    },
    "scaling": {
      "scale_up_increment": 2,
      "scale_down_increment": 1
    }
  }
}
